{
	"name": "wikidata-entity-reader",
	"version": "4.1.1",
	"description": "read information of wikidata entities in a simpler way",
	"keywords": [
		"wikidata",
		"entity"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/EdJoPaTo/wikidata-entity-reader.git"
	},
	"author": {
		"name": "EdJoPaTo",
		"email": "wikibase-npm-package@edjopato.de",
		"url": "https://edjopato.de"
	},
	"scripts": {
		"build": "rm -rf ./dist && tsc",
		"prepack": "npm run build",
		"test": "tsc --sourceMap && xo && c8 --all node --test --enable-source-maps"
	},
	"type": "module",
	"engines": {
		"node": ">=14"
	},
	"dependencies": {
		"wikibase-sdk": "^9.2.2"
	},
	"devDependencies": {
		"@types/node": "^18.18.13",
		"c8": "^10.1.2",
		"typescript": "^5.9.2",
		"xo": "^1.2.2"
	},
	"files": [
		"dist",
		"!*.test.*",
		"!test.*"
	],
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"xo": [
		{
			"rules": {
				"@typescript-eslint/parameter-properties": [
					"error",
					{
						"prefer": "class-property"
					}
				],
				"@typescript-eslint/prefer-readonly-parameter-types": "warn"
			}
		},
		{
			"files": [
				"**/*.test.*",
				"**/test.*"
			],
			"rules": {
				"@typescript-eslint/prefer-readonly-parameter-types": "off"
			}
		}
	]
}
